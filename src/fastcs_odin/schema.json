    "additionalProperties": false,
    "properties": {
        "controllers": {
            "items": {
                "$ref": "#/$defs/OdinControllerEntry"
            },
            "title": "Controllers",
            "type": "array"
        },
        "transport": {
            "items": {
                "anyOf": [
                    {
                        "$ref": "#/$defs/EpicsCATransport"
                    },
                    {
                        "$ref": "#/$defs/EpicsPVATransport"
                    },
                    {
                        "$ref": "#/$defs/RestTransport"
                    }
                ]
            },
            "title": "Transport",
            "type": "array"
        }
    },
    "required": [
        "controllers",
        "transport"
    ],
    "title": "OdinController",
    "type": "object"
}
